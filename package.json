{
  "name": "edu-resource",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.2",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "cf:build": "opennextjs-cloudflare build && node scripts/patch-cloudflare-worker.mjs",
