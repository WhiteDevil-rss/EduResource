{
  "name": "edu-resource",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.12.1",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "bench:api": "node scripts/benchmark-api.mjs",
    "bench:api:trend": "node scripts/benchmark-api-trend.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "cf:build": "opennextjs-cloudflare build && node scripts/patch-cloudflare-worker.mjs",
    "preview": "npm run cf:build && wrangler pages dev .open-next/assets",
    "deploy": "npm run cf:build && wrangler pages deploy .open-next/assets",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload"
  },
  "dependencies": {
    "babel-plugin-react-compiler": "^1.0.0",
    "boneyard-js": "^1.7.6",
    "firebase": "^12.12.0",
    "framer-motion": "^12.38.0",
    "jose": "^6.2.2",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hot-toast": "^2.6.0",
    "recharts": "^3.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@opennextjs/cloudflare": "^1.19.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "esbuild": "^0.28.0",
    "eslint": "^10.2.0",
    "eslint-config-next": "16.2.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "googleapis": "^171.4.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4",
    "wrangler": "^4.82.2"
  },
  "overrides": {
    "protobufjs": "^7.2.4",
    "jsonwebtoken": "^9.0.0",
    "http-proxy-agent": "^7.0.0",
    "teeny-request": "^9.0.0",
    "retry-request": "^8.0.2",
    "glob": "^12.0.0",
    "formdata-node": "^6.0.3"
  }
