    "framer-motion": "^11.18.2",
    "jose": "^6.2.2",
    "lucide-react": "^0.460.0",
    "next": "^15.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.18.0",
    "esbuild": "^0.28.0",
    "eslint": "^9.22.0",
    "eslint-config-next": "^15.2.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "typescript": "^5.9.3",
    "wrangler": "^4.80.0"
